CASE_STUDY_SIBERIA = dict(
    name='Siberia_CaseStudy',
    density=1018.0,
    ccr=17.5,
    s_feed=2.62,
    c_wt=np.nan,          # not available in supplied case-study block
    v_ppm=180.0,
