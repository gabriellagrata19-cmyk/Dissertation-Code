# ==========================================================================
# 12.3  Cook's Distance — influence diagnostics
# ==========================================================================
_section("12.3  COOK'S DISTANCE — Influence Diagnostics")
print("Threshold: D_i > 4/n flags an influential observation.")
print(f"{'Predictor':<14}{'Response':<22}{'n':>3}  {'4/n':>6}  Influential observations (label : D_i)")
print('-'*92)
def _cooks_uni(x, y, name, coeffs, k):
    n   = len(x)
    # Use RAW (un-floored) predictions for residuals — Cook's D is about model fit,
    # not displayed predictions.  Therefore we deliberately do NOT pass y_col here.
    yp  = _eval_form(x, name, coeffs)
    rss = float(np.sum((y-yp)**2))
    s2  = max(rss/(n-k), 1e-14)
    if name in ('linear','quadratic','logarithmic'):
        if name == 'linear':       X = np.column_stack([np.ones(n), x])
        elif name == 'quadratic':  X = np.column_stack([np.ones(n), x, x**2])
        else:                       X = np.column_stack([np.ones(n), np.log(x)])
    else:
        X = np.column_stack([np.ones(n), x])
    H   = X @ np.linalg.pinv(X.T @ X) @ X.T
    h   = np.diag(H)
    e   = y - yp
    D   = (e**2 / (k*s2)) * (h/(1-h)**2)
    return D

for pred in PREDICTORS_ALL:
    for resp in RESPONSES:
        res = fit_best(pred, resp, PRED_LABEL[pred], RESP_LABEL[resp])
        if res is None: continue
        b   = res['best']
        D   = _cooks_uni(res['xt'], res['yt'], b['name'], b['coeffs'], b['k'])
        n   = len(res['xt']); thr = 4.0/n
        flagged = [(res['ids_t'][i], D[i]) for i in range(n) if D[i] > thr]
        flagged.sort(key=lambda t: -t[1])
        flag_str = ',  '.join([f"{lbl}:{d:.3f}" for lbl,d in flagged]) if flagged else '(none)'
        print(f"{pred:<14}{resp:<22}{n:>3}  {thr:>6.3f}  {flag_str}")

