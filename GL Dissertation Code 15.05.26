# ==========================================================================
# SECTION 14 — SENSITIVITY ANALYSIS OF OPTIMISATION PARAMETERS
# ==========================================================================
# Appended to 9th_left_off.py after Section 13 (Operational Optimisation).
#
# Purpose:
#   Verify that the optimisation conclusions from Section 13 are robust to
#   the three modelling parameter choices made in Section 3.7:
#       (A) Sulfur weight W_S           : 1, 2, 4
#       (B) Carbon purity floor         : 88, 90, 92 wt%
#       (C) Penalty coefficient         : 100, 1000, 5000
#
#   Design: one-at-a-time (OAT) — one parameter varied per sweep while
#   the other two are held at their baseline values (W_S=2, C_floor=90, PEN=1000).
#   Four representative feed scenarios are assessed per run (36 runs total).
#
# All surrogate models (bY, bS, bC), prediction functions (_yield_pred,
# _sulf_pred, _carb_pred), solver settings, and feed SCENARIOS are inherited
# directly from Section 13 — nothing is redefined here.
# ==========================================================================

_section("14.0  SENSITIVITY ANALYSIS — Optimisation Parameter Robustness")

# --------------------------------------------------------------------------
# 14.1  Select four representative feeds that span the feasibility spectrum
# --------------------------------------------------------------------------
SENS_SCENARIOS = [
    ("Anqing (China, low-S)",         dict(density=1019.9, ccr=14.35, s_feed=1.04, v_ppm=45,  ni_ppm=15)),
    ("Abadan (Iran, med-high S)",     dict(density=1022.0, ccr=21.0,  s_feed=3.50, v_ppm=95,  ni_ppm=35)),
    ("Athabasca (Canada, heavy)",     dict(density=1045.0, ccr=23.5,  s_feed=4.80, v_ppm=210, ni_ppm=85)),
    ("Orinoco (Venezuela, ex-heavy)", dict(density=1055.0, ccr=25.0,  s_feed=5.20, v_ppm=350, ni_ppm=110)),
]
SENS_SHORT = ["Anqing", "Abadan", "Athabasca", "Orinoco"]

# --------------------------------------------------------------------------
# 14.2  Parametric optimiser
#       Wraps Section 13's prediction functions with overrideable parameters
# --------------------------------------------------------------------------
def _sens_objective(x, feed, w_s, c_floor, pen):
    T, tc = x
    Y = _yield_pred(feed, T, tc)
    S = _sulf_pred(feed, T, tc)       # floored at SULFUR_FLOOR (from Section 13)
    C = _carb_pred(feed)
    f  = -W_YIELD * Y + w_s * S
    f += pen * max(0.0, S - S_ANODE_MAX) ** 2
    f += pen * max(0.0, c_floor - C)    ** 2
    return f

def _sens_optimise(feed, w_s, c_floor, pen):
    """Run differential evolution with overridden w_s, c_floor, pen."""
    result = differential_evolution(
        _sens_objective,
        bounds=[(T_LO, T_HI), (CYC_LO, CYC_HI)],
        args=(feed, w_s, c_floor, pen),
        maxiter=400, popsize=20, tol=1e-9,
        mutation=(0.5, 1.5), recombination=0.9, seed=42)
    T_opt, tc_opt = result.x
    S        = _sulf_pred(feed, T_opt, tc_opt)
    C        = _carb_pred(feed)
    feasible = (S <= S_ANODE_MAX) and (C >= c_floor)
    return T_opt, tc_opt, S, C, feasible

# --------------------------------------------------------------------------
# 14.3  Sweep A — W_S varies (1, 2, 4); C_floor=90, PEN=1000
# --------------------------------------------------------------------------
print()
print("14.1  SWEEP A — Varying W_S  (C_floor = 90 wt%, PEN = 1000)")
print("-" * 92)

WS_VALS  = [1, 2, 4]
sweep_A  = []

print(f"{'W_S':>5} | "
      f"{'Anqing':^26} | {'Abadan':^26} | {'Athabasca':^26} | {'Orinoco':^26}")
print(f"{'':>5} | "
      f"{'T(°C)':>8} {'tc(h)':>8} {'Grade':>8} | "
      f"{'T(°C)':>8} {'tc(h)':>8} {'Grade':>8} | "
      f"{'T(°C)':>8} {'tc(h)':>8} {'Grade':>8} | "
      f"{'T(°C)':>8} {'tc(h)':>8} {'Grade':>8}")
print("-" * 120)

for ws in WS_VALS:
    row = {"W_S": ws}
    cols = []
    for (name, feed), short in zip(SENS_SCENARIOS, SENS_SHORT):
        T, tc, S, C, ok = _sens_optimise(feed, w_s=float(ws), c_floor=90.0, pen=1000.0)
        row[f"{short}_T"]  = round(T,  2)
        row[f"{short}_tc"] = round(tc, 2)
        row[f"{short}_ok"] = "OK" if ok else "FAIL"
        cols.append(f"{T:>8.2f} {tc:>8.2f} {'OK' if ok else 'FAIL':>8}")
    sweep_A.append(row)
    print(f"{ws:>5} | " + " | ".join(cols))

# --------------------------------------------------------------------------
# 14.4  Sweep B — Carbon floor varies (88, 90, 92 wt%); W_S=2, PEN=1000
# --------------------------------------------------------------------------
print()
print("14.2  SWEEP B — Varying Carbon Floor  (W_S = 2, PEN = 1000)")
print("-" * 92)

CF_VALS = [88.0, 90.0, 92.0]
sweep_B = []

print(f"{'C_floor':>8} | "
      f"{'Anqing':^26} | {'Abadan':^26} | {'Athabasca':^26} | {'Orinoco':^26}")
print(f"{'(wt%)':>8} | "
      f"{'T(°C)':>8} {'tc(h)':>8} {'Grade':>8} | "
      f"{'T(°C)':>8} {'tc(h)':>8} {'Grade':>8} | "
      f"{'T(°C)':>8} {'tc(h)':>8} {'Grade':>8} | "
