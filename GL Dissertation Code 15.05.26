# ==========================================================================
# SECTION 15 — BIVARIATE INV_T (ARRHENIUS) + NICKEL MODEL FOR COKE SULFUR
# ==========================================================================


print()
print("="*92)
print("15.0  BIVARIATE RESPONSE SURFACE — inv_T (Arrhenius) + Feed Nickel -> Coke Sulfur")
print("="*92)

from scipy.stats import f as _biv_f_dist, shapiro as _biv_shapiro
from scipy.optimize import differential_evolution as _biv_differential_evolution

# --------------------------------------------------------------------------
# Temperature conversion helpers
# --------------------------------------------------------------------------
def _c_to_inv_t(T_celsius):
    """Convert furnace outlet temperature (°C) to Arrhenius 1000/T (K⁻¹ × 10³)."""
    return 1000.0 / (np.asarray(T_celsius, dtype=float) + 273.15)

def _inv_t_to_c(inv_T):
    """Convert Arrhenius 1000/T back to °C for display."""
    return (1000.0 / np.asarray(inv_T, dtype=float)) - 273.15


# --------------------------------------------------------------------------
# Operating bounds expressed in °C (converted to inv_T internally)
# --------------------------------------------------------------------------
TEMP_NI_T_C_RANGE    = (440.0, 510.0)   # operator optimisation range in °C
TEMP_NI_T_C_PLOT     = (440.0, 520.0)   # display range in °C
TEMP_NI_NI_RANGE     = (0.0,   120.0)   # feed nickel window, ppm

# Convert °C bounds to inv_T bounds (note: higher T → lower inv_T, so bounds reverse)
TEMP_NI_INVT_RANGE   = (
    float(_c_to_inv_t(TEMP_NI_T_C_RANGE[1])),   # lower inv_T = higher T = 510°C
    float(_c_to_inv_t(TEMP_NI_T_C_RANGE[0]))    # upper inv_T = lower T = 440°C
)


# --------------------------------------------------------------------------
# Local model-selection / validation helper (unchanged from original)
# --------------------------------------------------------------------------
def _biv_extended_ic(y_obs, y_pred, k):
    n   = len(y_obs)
    rss = float(np.sum((y_obs - y_pred)**2))
    s2  = max(rss/n, 1e-14)
    ll  = -n/2 * (np.log(2*np.pi*s2) + 1)

    aic  = 2*k - 2*ll
    bic  = k*np.log(n) - 2*ll
    aicc = aic + (2*k*(k+1))/(n-k-1) if n > k+2 else np.nan
    hqc  = 2*k*np.log(np.log(max(n, 3))) - 2*ll

    tss  = float(np.sum((y_obs - y_obs.mean())**2))
    r2   = 1 - rss/max(tss, 1e-14)
    adjR2 = 1 - (1-r2)*(n-1)/max(n-k, 1)

    df1, df2 = max(k-1, 1), max(n-k, 1)
    msr  = (tss-rss)/df1
    mse  = rss/df2
    F    = msr/mse if mse > 0 else np.nan
    pF   = 1 - _biv_f_dist.cdf(F, df1, df2) if not np.isnan(F) else np.nan

    return dict(
        n=n, k=k, rss=rss, r2=r2, adjR2=adjR2,
        aic=aic, aicc=aicc, bic=bic, hqc=hqc,
        F=F, pF=pF, df1=df1, df2=df2
    )


# --------------------------------------------------------------------------
# 15.1  Fit the corrected bivariate surface: coke_s ~ inv_T + Ni
# --------------------------------------------------------------------------
def _fit_invt_ni_sulfur_surface():
    """
    Fit coke sulfur as a bivariate linear surface of 1000/T (Arrhenius
    temperature transform) and feed Ni content.
    Uses the df column 'inv_T' (already computed as 1000/(T+273.15)).
    """
    valid  = df['inv_T'].notna() & df['ni_ppm'].notna() & df['coke_s'].notna()
    t_mask = valid & TRAIN
    v_mask = valid & VAL

    iT_t = df.loc[t_mask, 'inv_T'].values.astype(float)
    Ni_t = df.loc[t_mask, 'ni_ppm'].values.astype(float)
    y_t  = df.loc[t_mask, 'coke_s'].values.astype(float)
    T_t_c = df.loc[t_mask, 'temp_c'].values.astype(float)   # for display only

    iT_v = df.loc[v_mask, 'inv_T'].values.astype(float)
    Ni_v = df.loc[v_mask, 'ni_ppm'].values.astype(float)
    y_v  = df.loc[v_mask, 'coke_s'].values.astype(float)
    T_v_c = df.loc[v_mask, 'temp_c'].values.astype(float)   # for display only

    if len(y_t) < 4:
        raise ValueError(
            "Not enough complete training rows for inv_T + ni_ppm -> coke_s surface."
        )

    # Design matrix: [1 | inv_T | Ni]
    A_t = np.column_stack([np.ones(len(y_t)), iT_t, Ni_t])
    beta, *_ = np.linalg.lstsq(A_t, y_t, rcond=None)

    yhat_train_raw = A_t @ beta
    yhat_train     = apply_floor_if_sulfur(yhat_train_raw, 'coke_s')

    if len(y_v) > 0:
        A_v          = np.column_stack([np.ones(len(y_v)), iT_v, Ni_v])
        yhat_val_raw = A_v @ beta
        yhat_val     = apply_floor_if_sulfur(yhat_val_raw, 'coke_s')
        rmse_val     = float(np.sqrt(np.mean((y_v - yhat_val)**2)))
    else:
        yhat_val_raw = np.asarray([])
        yhat_val     = np.asarray([])
        rmse_val     = np.nan

    raw_diag    = _biv_extended_ic(y_t, yhat_train_raw, k=3)

    rss_final   = float(np.sum((y_t - yhat_train)**2))
    tss         = float(np.sum((y_t - y_t.mean())**2))
    r2_final    = 1 - rss_final / max(tss, 1e-14)
    adjR2_final = 1 - (1-r2_final)*(len(y_t)-1)/max(len(y_t)-3, 1)

    return dict(
        beta=beta,
        iT_t=iT_t, Ni_t=Ni_t, y_t=y_t, T_t_c=T_t_c,
        iT_v=iT_v, Ni_v=Ni_v, y_v=y_v, T_v_c=T_v_c,
        ids_t=df.index[t_mask].tolist(),
        ids_v=df.index[v_mask].tolist(),
        yhat_train_raw=yhat_train_raw,
        yhat_train=yhat_train,
        yhat_val_raw=yhat_val_raw,
        yhat_val=yhat_val,
        rmse_val=rmse_val,
        raw_diag=raw_diag,
        r2_final=r2_final,
        adjR2_final=adjR2_final,
        n_train=len(y_t),
        n_val=len(y_v)
    )


INVT_NI_S = _fit_invt_ni_sulfur_surface()


def _invt_ni_s_raw(inv_T, ni_ppm):
    """Unfloored bivariate OLS prediction from inv_T and Ni."""
    b = INVT_NI_S['beta']
    return b[0] + b[1]*np.asarray(inv_T, dtype=float) + b[2]*np.asarray(ni_ppm, dtype=float)


def _invt_ni_s_pred(inv_T, ni_ppm):
    """Final coke sulfur prediction after physical sulfur floor."""
    return apply_floor_if_sulfur(_invt_ni_s_raw(inv_T, ni_ppm), 'coke_s')


def _invt_ni_s_pred_from_celsius(T_celsius, ni_ppm):
    """Convenience wrapper: accepts T in °C, converts internally to inv_T."""
    return _invt_ni_s_pred(_c_to_inv_t(T_celsius), ni_ppm)


# --------------------------------------------------------------------------
# Print fitted equation and diagnostics
# --------------------------------------------------------------------------
b = INVT_NI_S['beta']
print()
print("Fitted bivariate surface (Arrhenius-corrected):")
print(f"  coke_s_raw = {b[0]:.4f} + ({b[1]:+.6f})·(1000/T) + ({b[2]:+.6f})·Ni_ppm")
print(f"  coke_s_final = max(coke_s_raw, {SULFUR_FLOOR:.2f})")
print()
print("  NOTE ON SIGN of (1000/T) coefficient:")
if b[1] > 0:
    print("  Positive: higher 1000/T (lower furnace T) → higher predicted coke sulfur.")
    print("  This is physically expected: lower T retains more sulfur in coke.")
else:
    print("  Negative: higher 1000/T (lower furnace T) → lower predicted coke sulfur.")
    print("  This is a confound artefact — feed quality confounds the temperature signal.")
print()

print("Training diagnostics:")
print(f"  n_train                 : {INVT_NI_S['n_train']}")
print(f"  Raw OLS R²              : {INVT_NI_S['raw_diag']['r2']:.4f}")
print(f"  Final clipped R²        : {INVT_NI_S['r2_final']:.4f}")
print(f"  Final clipped adj. R²   : {INVT_NI_S['adjR2_final']:.4f}")
print(f"  Fisher F-test, raw OLS  : F = {INVT_NI_S['raw_diag']['F']:.3f}, p = {INVT_NI_S['raw_diag']['pF']:.4g}")
print(f"  AIC / AICc / BIC / HQC  : {INVT_NI_S['raw_diag']['aic']:.3f} / {INVT_NI_S['raw_diag']['aicc']:.3f} / "
      f"{INVT_NI_S['raw_diag']['bic']:.3f} / {INVT_NI_S['raw_diag']['hqc']:.3f}")
print()

print("Validation diagnostics:")
print(f"  n_validation            : {INVT_NI_S['n_val']}")
print(f"  Overall validation RMSE : {INVT_NI_S['rmse_val']:.4f} wt% coke S")

if INVT_NI_S['n_val'] > 0:
    origins_v = np.asarray([df.loc[i, 'origin'] for i in INVT_NI_S['ids_v']])
    for org in sorted(set(origins_v)):
        mask = origins_v == org
        if mask.any():
            rmse_org = float(np.sqrt(
                np.mean((INVT_NI_S['y_v'][mask] - INVT_NI_S['yhat_val'][mask])**2)
            ))
            print(f"  {org:<22} RMSE : {rmse_org:.4f} wt% coke S")


# Cook's Distance and Shapiro-Wilk
X_cook = np.column_stack([np.ones(INVT_NI_S['n_train']), INVT_NI_S['iT_t'], INVT_NI_S['Ni_t']])
H      = X_cook @ np.linalg.pinv(X_cook.T @ X_cook) @ X_cook.T
h      = np.diag(H)

resid_raw = INVT_NI_S['y_t'] - INVT_NI_S['yhat_train_raw']
s2 = max(float(np.sum(resid_raw**2)) / max(INVT_NI_S['n_train']-3, 1), 1e-14)

D        = (resid_raw**2 / (3*s2)) * (h / (1-h)**2)
cook_thr = 4.0 / INVT_NI_S['n_train']

flagged  = [(INVT_NI_S['ids_t'][i], D[i]) for i in range(INVT_NI_S['n_train']) if D[i] > cook_thr]
flagged.sort(key=lambda z: -z[1])
flag_str = ', '.join([f"{lbl}:{val:.3f}" for lbl, val in flagged]) if flagged else "(none)"

try:
    W_shap, p_shap = _biv_shapiro(resid_raw)
except Exception:
    W_shap, p_shap = np.nan, np.nan

print()
print("Residual / influence checks:")
print(f"  Shapiro-Wilk residual test: W = {W_shap:.4f}, p = {p_shap:.4f}")
print(f"  Cook's distance threshold : 4/n = {cook_thr:.4f}")
print(f"  Influential observations  : {flag_str}")


# --------------------------------------------------------------------------
# 15.2  Operational optimisation: minimise coke sulfur over T at fixed Ni
# --------------------------------------------------------------------------
print()
print("="*92)
print("15.2  FURNACE TEMPERATURE OPTIMISATION AT FIXED FEED-NICKEL LEVELS")
print("="*92)
print("Interpretation: furnace outlet temperature is the operator variable;")
print("Ni is treated as a fixed feed-quality input.")
print(f"Temperature search range  : {TEMP_NI_T_C_RANGE[0]:.0f}–{TEMP_NI_T_C_RANGE[1]:.0f} °C")
print(f"  (inv_T range            : {TEMP_NI_INVT_RANGE[0]:.4f}–{TEMP_NI_INVT_RANGE[1]:.4f})")
print(f"Sulfur floor enforced     : coke_s >= {SULFUR_FLOOR:.2f} wt%")
print()

INVT_NI_SCENARIOS = [
    ("Low-Ni sweet / Anqing-like",    15.0),
    ("Medium-Ni Abadan-like",         35.0),
    ("Higher-Ni PlantB-like",         60.0),
    ("Canadian bitumen-like",         85.0),
    ("Extra-heavy Orinoco-like",     110.0),
]


def _temp_only_optimum_for_ni_corrected(ni_ppm, t_c_bounds=TEMP_NI_T_C_RANGE):
    """
    Grid-search optimum furnace outlet temperature at a fixed nickel level.
    Searches in °C space; converts to inv_T internally for prediction.
    Returns (T_opt_celsius, S_final, S_raw).
    """
    T_c_grid = np.linspace(t_c_bounds[0], t_c_bounds[1], 700)
    iT_grid  = _c_to_inv_t(T_c_grid)
    S_raw    = _invt_ni_s_raw(iT_grid, ni_ppm)
    S_fin    = _invt_ni_s_pred(iT_grid, ni_ppm)
    j        = int(np.argmin(S_fin))
    return float(T_c_grid[j]), float(S_fin[j]), float(S_raw[j])


invt_ni_opt_records = []

print(f"{'Scenario':<34}{'Ni ppm':>9}{'T_opt °C':>12}{'S_raw':>10}{'S_final':>10}  Note")
print("-"*92)

for name, ni in INVT_NI_SCENARIOS:
    T_opt_c, S_fin, S_raw = _temp_only_optimum_for_ni_corrected(ni)
    note = "floor active" if S_raw < SULFUR_FLOOR else "model active"
    print(f"{name:<34}{ni:>9.1f}{T_opt_c:>12.2f}{S_raw:>10.3f}{S_fin:>10.3f}  {note}")
    invt_ni_opt_records.append(dict(
        scenario=name,
        ni_ppm=ni,
        T_opt_C=T_opt_c,
        inv_T_opt=float(_c_to_inv_t(T_opt_c)),
        coke_s_raw=S_raw,
        coke_s_final=S_fin,
        sulfur_floored=(S_raw < SULFUR_FLOOR)
    ))


# Joint sensitivity optimum (for feed blending / selection context)
def _joint_invt_ni_objective(x):
    T_c, ni_ppm = x
    return float(_invt_ni_s_pred_from_celsius(T_c, ni_ppm))


joint_result = _biv_differential_evolution(
    _joint_invt_ni_objective,
    bounds=[TEMP_NI_T_C_RANGE, TEMP_NI_NI_RANGE],
    maxiter=300,
    popsize=15,
    tol=1e-9,
    seed=42
)

T_joint_c  = joint_result.x[0]
Ni_joint   = joint_result.x[1]
iT_joint   = float(_c_to_inv_t(T_joint_c))
S_joint_raw = float(_invt_ni_s_raw(iT_joint, Ni_joint))
S_joint     = float(_invt_ni_s_pred(iT_joint, Ni_joint))

print()
print("Joint furnace temperature + feed-Ni sensitivity optimum:")
print("  NOTE: Ni is a feed/blending property, not an operational degree of freedom.")
print(f"  Best T (°C)            : {T_joint_c:.2f} °C  (inv_T = {iT_joint:.4f})")
print(f"  Best Ni                : {Ni_joint:.2f} ppm")
print(f"  Predicted coke sulfur  : {S_joint:.3f} wt%  (raw OLS = {S_joint_raw:.3f})")

try:
    pd.DataFrame(invt_ni_opt_records).to_csv('invt_ni_sulfur_optimisation.csv', index=False)
    print("\nSaved: invt_ni_sulfur_optimisation.csv")
except Exception as ex:
    print(f"\nCSV save skipped: {ex}")


# --------------------------------------------------------------------------
# 15.3  Four-panel figure: 3D surface + 2D contour + predicted vs actual
#       + operator T optimisation curves
#
# x-axis on all spatial plots uses real °C for operator readability.
# The contour grid is computed in inv_T space; only the tick labels are °C.
# --------------------------------------------------------------------------
def draw_invt_ni_sulfur_surface():

    # Build display grid in °C, convert to inv_T for predictions
    T_c_grid  = np.linspace(TEMP_NI_T_C_PLOT[0], TEMP_NI_T_C_PLOT[1], 50)
    Ni_grid   = np.linspace(TEMP_NI_NI_RANGE[0],  TEMP_NI_NI_RANGE[1],  50)

    TG_c, NG  = np.meshgrid(T_c_grid, Ni_grid)
    TG_invt   = _c_to_inv_t(TG_c)
    SG        = _invt_ni_s_pred(TG_invt, NG)

    # Combine training + validation for scatter
    T_all_c  = np.concatenate([INVT_NI_S['T_t_c'], INVT_NI_S['T_v_c']]) if INVT_NI_S['n_val'] else INVT_NI_S['T_t_c']
    Ni_all   = np.concatenate([INVT_NI_S['Ni_t'],  INVT_NI_S['Ni_v']]) if INVT_NI_S['n_val'] else INVT_NI_S['Ni_t']
    y_all    = np.concatenate([INVT_NI_S['y_t'],   INVT_NI_S['y_v']]) if INVT_NI_S['n_val'] else INVT_NI_S['y_t']
    yhat_all = np.concatenate([INVT_NI_S['yhat_train'], INVT_NI_S['yhat_val']]) if INVT_NI_S['n_val'] else INVT_NI_S['yhat_train']

    ids_all    = INVT_NI_S['ids_t'] + INVT_NI_S['ids_v']
    is_val_all = [False]*len(INVT_NI_S['ids_t']) + [True]*len(INVT_NI_S['ids_v'])

    fig = plt.figure(figsize=(17, 10))
    fig.suptitle(
        "Figure 15 — Bivariate Coke-Sulfur Surface: Furnace Outlet Temperature (Arrhenius) + Feed Nickel Content",
        fontsize=13,
        fontweight='bold',
        y=1.02
    )

    # ------------------------------------------------------------------
    # Panel 1: 3D surface (x-axis in °C for readability)
    # ------------------------------------------------------------------
    ax1 = fig.add_subplot(2, 2, 1, projection='3d')
    ax1.plot_surface(TG_c, NG, SG, cmap='magma', alpha=0.42, linewidth=0)

    for i, lbl in enumerate(ids_all):
        sty = ORIGIN_STYLE.get(df.loc[lbl, 'origin'], dict(color='grey', marker='o'))
        val = is_val_all[i]
        ax1.scatter(
            T_all_c[i], Ni_all[i], y_all[i],
            color=sty['color'],
            marker=sty['marker'],
            s=85 if val else 40,
            edgecolors='black' if val else 'white',
            linewidths=1.0 if val else 0.5
        )

    ax1.scatter(
        T_joint_c, Ni_joint, S_joint,
        marker='X', color='red', s=130,
        edgecolors='black', linewidths=0.9,
        label='Joint optimum'
    )

    ax1.set_xlabel('Furnace Outlet T (°C)')
    ax1.set_ylabel('Feed Nickel (ppm)')
    ax1.set_zlabel('Predicted Coke Sulfur (wt%)')
    ax1.set_title('3D response surface\n(T displayed in °C; 1000/T used in model)')
    ax1.view_init(elev=24, azim=235)

    # ------------------------------------------------------------------
    # Panel 2: 2D contour (x-axis in °C)
    # ------------------------------------------------------------------
    ax2 = fig.add_subplot(2, 2, 2)

    cf   = ax2.contourf(TG_c, NG, SG, levels=20, cmap='magma', alpha=0.58)
    cbar = plt.colorbar(cf, ax=ax2)
    cbar.set_label('Predicted Coke Sulfur (wt%)')

    for i, lbl in enumerate(ids_all):
        sty = ORIGIN_STYLE.get(df.loc[lbl, 'origin'], dict(color='grey', marker='o'))
        val = is_val_all[i]
        ax2.scatter(
            T_all_c[i], Ni_all[i],
            color=sty['color'],
            marker=sty['marker'],
            s=115 if val else 45,
            edgecolors='black' if val else 'white',
            linewidths=1.2 if val else 0.5
        )
        if val:
            ax2.annotate(
                lbl, (T_all_c[i], Ni_all[i]),
                xytext=(5, 5), textcoords='offset points',
                fontsize=8, fontweight='bold'
            )

    ax2.scatter(
        T_joint_c, Ni_joint,
        marker='X', color='red', s=160,
        edgecolors='black', linewidths=0.9,
        label='Joint optimum'
    )

    ax2.set_xlim(TEMP_NI_T_C_PLOT)
    ax2.set_ylim(TEMP_NI_NI_RANGE)
    ax2.set_xlabel('Furnace Outlet Temperature (°C)')
    ax2.set_ylabel('Feed Nickel Content (ppm)')
    ax2.set_title('2D contour projection + validation points\n(model uses 1000/T internally)')
    ax2.legend(loc='upper right', fontsize=8)

    # ------------------------------------------------------------------
    # Panel 3: Predicted vs actual
    # ------------------------------------------------------------------
    ax3 = fig.add_subplot(2, 2, 3)

    lo = min(y_all.min(), yhat_all.min()) * 0.92
    hi = max(y_all.max(), yhat_all.max()) * 1.08
    ax3.plot([lo, hi], [lo, hi], color='grey', ls='--', label='1:1 line')

    for i, lbl in enumerate(ids_all):
        sty = ORIGIN_STYLE.get(df.loc[lbl, 'origin'], dict(color='grey', marker='o'))
        val = is_val_all[i]
        ax3.scatter(
            y_all[i], yhat_all[i],
            color=sty['color'],
            marker=sty['marker'],
            s=115 if val else 45,
            edgecolors='black' if val else 'white',
            linewidths=1.2 if val else 0.5
        )

    ax3.set_xlim(lo, hi)
    ax3.set_ylim(lo, hi)
    ax3.set_aspect('equal', adjustable='box')
    ax3.set_xlabel('Observed Coke Sulfur (wt%)')
    ax3.set_ylabel('Predicted Coke Sulfur (wt%)')
    ax3.set_title('Predicted vs actual')

    ax3.text(
        0.05, 0.95,
        f"Raw OLS R² = {INVT_NI_S['raw_diag']['r2']:.3f}\n"
        f"Final clipped R² = {INVT_NI_S['r2_final']:.3f}\n"
        f"Val RMSE = {INVT_NI_S['rmse_val']:.3f} wt%\n"
        f"p(F) = {INVT_NI_S['raw_diag']['pF']:.4f}\n"
        f"Predictor: 1000/T (Arrhenius)",
        transform=ax3.transAxes,
        va='top', fontsize=9,
        bbox=dict(boxstyle='round,pad=0.3', facecolor='white', ec='#ccc', alpha=0.9)
    )

    # ------------------------------------------------------------------
    # Panel 4: Operator T optimisation curves at fixed Ni
    # x-axis in °C; predictions computed via inv_T internally
    # ------------------------------------------------------------------
    ax4 = fig.add_subplot(2, 2, 4)

    T_c_line  = np.linspace(TEMP_NI_T_C_RANGE[0], TEMP_NI_T_C_RANGE[1], 300)
    iT_line   = _c_to_inv_t(T_c_line)

    for rec in invt_ni_opt_records:
        ni      = rec['ni_ppm']
        S_line  = _invt_ni_s_pred(iT_line, ni)
        ax4.plot(T_c_line, S_line, lw=1.8, label=f"{ni:.0f} ppm Ni")
        ax4.scatter(
            rec['T_opt_C'], rec['coke_s_final'],
            s=45, edgecolors='black', zorder=5
        )

    ax4.axhline(SULFUR_FLOOR, color='#7f8c8d', lw=0.9, ls=':', alpha=0.8)
    ax4.set_xlabel('Furnace Outlet Temperature (°C)')
    ax4.set_ylabel('Predicted Coke Sulfur (wt%)')
    ax4.set_title('Operator T optimisation at fixed Ni\n(1000/T used in model; °C on axis)')
    ax4.legend(fontsize=8, ncol=2)

    # ------------------------------------------------------------------
    # Siberia case study overlay (if Section 14 has been run)
    # ------------------------------------------------------------------
    if 'CASE_STUDY_SIBERIA' in globals():
        try:
            T_case_c = float(CASE_STUDY_SIBERIA['temp_c'])
            Ni_case  = float(CASE_STUDY_SIBERIA['ni_ppm'])
            S_case   = float(CASE_STUDY_SIBERIA['coke_s'])

            if np.isfinite(T_case_c) and np.isfinite(Ni_case) and np.isfinite(S_case):
                S_case_pred = float(_invt_ni_s_pred_from_celsius(T_case_c, Ni_case))

                ax2.scatter(
                    T_case_c, Ni_case,
                    color='red', marker='*', s=190,
                    edgecolors='black', linewidths=0.9, zorder=8
                )
                ax2.annotate(
                    'Siberia case', (T_case_c, Ni_case),
                    xytext=(6, -12), textcoords='offset points',
                    fontsize=8, fontweight='bold', color='red'
                )
                ax3.scatter(
                    S_case, S_case_pred,
                    color='red', marker='*', s=190,
                    edgecolors='black', linewidths=0.9, zorder=8
                )
        except Exception:
            pass

    fig.legend(
        handles=legend_handles(),
        loc='lower center',
        ncol=7,
        bbox_to_anchor=(0.5, -0.01),
        fontsize=9,
        title='Feed Geographic Origin'
    )

    plt.tight_layout(rect=[0, 0.04, 1, 0.97])
    plt.show()


draw_invt_ni_sulfur_surface()

