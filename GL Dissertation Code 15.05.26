    - CASE_STUDY_SIBERIA['coke_s']
    - COKE_N
    - COKE_ASH
    - ((CASE_STUDY_SIBERIA['v_ppm'] + CASE_STUDY_SIBERIA['ni_ppm'])
       / (CASE_STUDY_SIBERIA['coke_yld'] * 100.0) * OXIDE_FCTR)
)


def _case_val(key):
    return CASE_STUDY_SIBERIA.get(key, np.nan)


def _case_prediction_from_univariate(res):
    """Return the univariate fitted prediction at the Siberia case-study x-value."""
    if res is None:
        return np.nan
    x = _case_val(res['x_col'])
    if np.isnan(x):
        return np.nan
    yhat = _eval_form(np.asarray([x], dtype=float),
                      res['best']['name'],
                      res['best']['coeffs'],
                      y_col=res.get('y_col'))
    return float(np.asarray(yhat).ravel()[0])


def draw_case_overlay(res, ax, case_label='Siberia case study', xlim=None, ylim=None):
    """Draw a regression plot with background data faded and the Siberia point highlighted."""
    if res is None:
        ax.set_visible(False)
        return

    xt, yt, xv, yv, best = res['xt'], res['yt'], res['xv'], res['yv'], res['best']
    x_case = _case_val(res['x_col'])
    y_case = _case_val(res['y_col'])

    if np.isnan(x_case) or np.isnan(y_case):
        ax.set_visible(False)
        return

    # Use the same kinetic plot limits as the main regression figures.
    if xlim is None and res['x_col'] == 'inv_T':
        xlim = SULFUR_INV_T_PLOT_LIM if res.get('is_sulfur') else INV_T_PLOT_LIM
    if xlim is None and res['x_col'] == 'ln_cycle':
        xlim = LN_CYCLE_PLOT_LIM

    # Include the case-study point when calculating non-prescribed limits.
    if xlim is None:
        x_all = np.concatenate([xt, xv, np.asarray([x_case], dtype=float)]) if len(xv) else np.concatenate([xt, np.asarray([x_case], dtype=float)])
        dx = max(x_all.max() - x_all.min(), 1e-9)
        lo, hi = x_all.min() - 0.05*dx, x_all.max() + 0.05*dx
    else:
        lo, hi = xlim

    xr = np.linspace(max(lo, 1e-6) if best['name'] in ('logarithmic','exponential') else lo, hi, 300)
    yr = _eval_form(xr, best['name'], best['coeffs'], y_col=res.get('y_col'))

    if yr is not None:
        pi_half = _pi(xr, xt, yt, best['yp'], best['k'])
        lo_band = yr - pi_half
        hi_band = yr + pi_half
        if res.get('is_sulfur'):
            lo_band = np.maximum(lo_band, SULFUR_FLOOR)
        ax.fill_between(xr, lo_band, hi_band, color='#2c3e50', alpha=0.08, zorder=1)
        ax.plot(xr, yr, color='#2c3e50', lw=2.0, zorder=4, label='Regression fit')

    # Existing dataset shown faintly only for context.
    ax.scatter(xt, yt, color='#2c3e50', s=38, alpha=0.16, edgecolors='none', label='Training data (faded)', zorder=2)
    if len(xv) > 0:
        ax.scatter(xv, yv, color='#c0392b', s=52, alpha=0.12, edgecolors='none', label='Validation data (faded)', zorder=2)

    yhat_case = _case_prediction_from_univariate(res)
    if not np.isnan(yhat_case):
        ax.scatter([x_case], [yhat_case], marker='o', s=75, facecolors='none',
                   edgecolors='black', linewidths=1.2, zorder=6, label='Case predicted')
        ax.plot([x_case, x_case], [y_case, yhat_case], color='black', lw=0.9, ls=':', alpha=0.65, zorder=5)

    ax.scatter([x_case], [y_case], color='red', marker='X', s=170,
               edgecolors='black', linewidths=0.9, zorder=7, label=case_label)
    ax.annotate(CASE_STUDY_SIBERIA['name'], (x_case, y_case), xytext=(6, 6),
                textcoords='offset points', fontsize=8, fontweight='bold', color='red')

    if res.get('is_sulfur'):
        ax.axhline(SULFUR_FLOOR, color='#7f8c8d', lw=0.9, ls=':', alpha=0.8, zorder=3)

    ax.set_xlabel(res['x_phys'], fontsize=9)
    ax.set_ylabel(res['y_label'], fontsize=9)
    ax.set_title(f"{res['x_phys']} → {res['y_label']}", fontsize=10, fontweight='bold')
    ax.text(0.03, 0.97,
            f"Best: {best['name']}\nR² = {best['r2']:.3f}\nCase actual = {y_case:.2f}\nCase pred. = {yhat_case:.2f}",
            transform=ax.transAxes, fontsize=8, va='top',
            bbox=dict(boxstyle='round,pad=0.3', facecolor='white', ec='#ccc', alpha=0.88))

    if xlim:
        ax.set_xlim(xlim)
    if ylim:
        ax.set_ylim(ylim)

    if res['x_col'] == 'inv_T':
        secax = ax.secondary_xaxis('top', functions=(invT_to_C, C_to_invT))
        secax.set_xlabel('Real Temperature (°C)', fontsize=8, color='#c0392b')
        secax.tick_params(axis='x', labelsize=7, colors='#c0392b')
    elif res['x_col'] == 'ln_cycle':
        secax = ax.secondary_xaxis('top', functions=(ln_to_h, h_to_ln))
        secax.set_xlabel('Real Cycle Time (h)', fontsize=8, color='#c0392b')
        secax.tick_params(axis='x', labelsize=7, colors='#c0392b')


def make_case_overlay_figure(specs, fig_title, ncols=2):
    n = len(specs)
    nrows = int(np.ceil(n / ncols))
    fig, axes = plt.subplots(nrows, ncols, figsize=(7*ncols, 4.6*nrows))
    axes = np.asarray(axes).reshape(-1)
    fig.suptitle(fig_title, fontsize=14, fontweight='bold', y=1.01)

    for ax, spec in zip(axes, specs):
        x_col, y_col, x_label, y_label = spec[:4]
        xlim = spec[4] if len(spec) > 4 else None
        ylim = spec[5] if len(spec) > 5 else None
        res = fit_best(x_col, y_col, x_label, y_label)
        draw_case_overlay(res, ax, xlim=xlim, ylim=ylim)

    for ax in axes[len(specs):]:
        ax.set_visible(False)

    handles, labels = axes[0].get_legend_handles_labels()
    # Keep legend compact and non-repetitive.
    unique = dict(zip(labels, handles))
    fig.legend(unique.values(), unique.keys(), loc='lower center', ncol=4,
               bbox_to_anchor=(0.5, -0.01), fontsize=9)
    plt.tight_layout(rect=[0, 0.04, 1, 0.97])
    plt.show()


