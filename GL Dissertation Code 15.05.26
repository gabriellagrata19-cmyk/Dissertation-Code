_section("12.6  VARIANCE INFLATION FACTOR — Multicollinearity Audit (training set)")
print("Rule of thumb: VIF > 10 indicates severe multicollinearity.")
vif_block = ['density','ccr','s_feed','c_wt','v_ppm','ni_ppm','inv_T','ln_cycle']
X = train_df[vif_block].dropna().values
print(f"\n  {'Predictor':<14}{'VIF':>10}")
for j, v in enumerate(vif_block):
    Xj    = X[:, j]
    Xrest = np.delete(X, j, axis=1)
    A = np.column_stack([np.ones(len(Xj)), Xrest])
    beta, *_ = np.linalg.lstsq(A, Xj, rcond=None)
    yp = A @ beta
    r2 = 1 - np.sum((Xj-yp)**2)/max(np.sum((Xj-Xj.mean())**2), 1e-14)
    vif = 1.0/max(1.0 - r2, 1e-14)
    print(f"  {v:<14}{vif:>10.2f}")

print("\nPairwise Pearson correlations (training set):")
corr = train_df[vif_block].corr()
hdr = '         ' + ' '.join([f"{v[:7]:>8}" for v in vif_block])
print(hdr)
for v in vif_block:
    row = ' '.join([f"{corr.loc[v,w]:>8.3f}" for w in vif_block])
    print(f"{v[:7]:<9}{row}")

