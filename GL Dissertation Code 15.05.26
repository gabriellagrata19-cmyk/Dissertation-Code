_section("12.8  APPARENT ACTIVATION ENERGY (Arrhenius linearisation)")
res_arr = fit_best('inv_T', 'coke_yld', '1000/T (1/K)', 'Coke Yield')
if res_arr is not None:
    valid = df['inv_T'].notna() & df['coke_yld'].notna() & (df['coke_yld'] > 0) & TRAIN
    x = df.loc[valid,'inv_T'].values
