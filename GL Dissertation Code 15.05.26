_section("12.4  SHAPIRO-WILK RESIDUAL NORMALITY (univariate, best form)")
print(f"{'Predictor':<14}{'Response':<22}{'n':>3}  {'W':>7}  {'p':>7}  Verdict")
print('-'*92)
for pred in PREDICTORS_ALL:
    for resp in RESPONSES:
        res = fit_best(pred, resp, PRED_LABEL[pred], RESP_LABEL[resp])
        if res is None: continue
        b = res['best']
        e = res['yt'] - b['yp']
        if len(e) < 3: continue
        try:
            W, p = shapiro(e)
        except Exception:
            W, p = np.nan, np.nan
        verdict = "Normal (fail to reject H0)" if (not np.isnan(p) and p > 0.05) else "Non-normal (reject H0)"
        print(f"{pred:<14}{resp:<22}{len(e):>3}  {W:>7.4f}  {p:>7.4f}  {verdict}")

# ==========================================================================
# 12.5  Wilks' Lambda
# ==========================================================================
_section("12.5  WILKS' LAMBDA — Multivariate Origin Distinctiveness (training set)")
train_df = df[TRAIN].copy()
origin_groups = [g for g, sub in train_df.groupby('origin') if len(sub) >= 2]
wilks_vars    = ['density','ccr','s_feed','v_ppm','ni_ppm','c_wt']
print(f"Origins included (n_g >= 2): {origin_groups}")
print(f"Predictor block tested:      {wilks_vars}")
groups_data = [train_df[train_df['origin']==g][wilks_vars].dropna().values for g in origin_groups]
groups_data = [g for g in groups_data if g.shape[0] >= 2]
if len(groups_data) >= 2:
    all_data = np.vstack(groups_data)
    grand    = all_data.mean(axis=0)
    p        = all_data.shape[1]
    n_total  = all_data.shape[0]
    g_count  = len(groups_data)
    W = np.zeros((p,p)); B = np.zeros((p,p))
    for gd in groups_data:
        gm = gd.mean(axis=0)
        d_in  = gd - gm
        W += d_in.T @ d_in
        d_bt = (gm - grand).reshape(-1,1)
        B += gd.shape[0] * (d_bt @ d_bt.T)
    T = W + B
    try:
        lam = float(np.linalg.det(W) / np.linalg.det(T))
    except Exception:
        lam = np.nan
    df_num = p * (g_count - 1)
    bartlett = -(n_total - 1 - (p + g_count)/2) * np.log(max(lam, 1e-300))
    from scipy.stats import chi2
    p_val = 1 - chi2.cdf(bartlett, df_num) if not np.isnan(lam) else np.nan
    print(f"\n  Wilks' Λ            = {lam:.5f}")
    print(f"  Bartlett χ²         = {bartlett:.3f}  (df = {df_num})")
    print(f"  p-value             = {p_val:.4g}")
    print(f"  Verdict             = {'Origins are MULTIVARIATE-DISTINCT (reject H0)' if p_val < 0.05 else 'Origins are NOT statistically distinct'}")
else:
    print("Insufficient origins with n>=2 for Wilks' Lambda.")

print("\nPer-variable one-way ANOVA across origins (training set):")
print(f"  {'Variable':<14}{'F':>10}  {'p':>10}")
for v in wilks_vars:
    samples = [train_df.loc[train_df['origin']==g, v].dropna().values for g in origin_groups]
    samples = [s for s in samples if len(s) > 0]
    if len(samples) >= 2:
        try:
            F_, p_ = f_oneway(*samples)
        except Exception:
            F_, p_ = np.nan, np.nan
        print(f"  {v:<14}{F_:>10.3f}  {p_:>10.4g}")

