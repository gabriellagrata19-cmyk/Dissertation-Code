def fit_surface(x1_col, x2_col, y_col):
    valid  = df[x1_col].notna() & df[x2_col].notna() & df[y_col].notna()
    t_mask = valid & TRAIN
    v_mask = valid & VAL
    x1t, x2t, yt = df.loc[t_mask, x1_col].values, df.loc[t_mask, x2_col].values, df.loc[t_mask, y_col].values
    x1v, x2v, yv = df.loc[v_mask, x1_col].values, df.loc[v_mask, x2_col].values, df.loc[v_mask, y_col].values

    A = np.column_stack([np.ones(len(x1t)), x1t, x2t])
    betas, _, _, _ = np.linalg.lstsq(A, yt, rcond=None)

    # validation predictions: apply sulfur floor if response is coke_s
    if len(x1v) > 0:
        yv_pred_raw = betas[0] + betas[1]*x1v + betas[2]*x2v
        yv_pred = apply_floor_if_sulfur(yv_pred_raw, y_col)
        rmse_v  = float(np.sqrt(np.mean((yv - yv_pred)**2)))
    else:
        rmse_v = np.nan
    r2 = 1 - np.sum((yt - A @ betas)**2) / max(np.sum((yt-yt.mean())**2), 1e-14)

    return dict(x1t=x1t, x2t=x2t, yt=yt, ids_t=df.index[t_mask].tolist(),
                x1v=x1v, x2v=x2v, yv=yv, ids_v=df.index[v_mask].tolist(),
                betas=betas, r2=r2, rmse_v=rmse_v,
                x1_col=x1_col, x2_col=x2_col, y_col=y_col,
                is_sulfur=is_sulfur_response(y_col))

def draw_multivariate_trio(s, x1l, x2l, yl, title, cmap):
    fig = plt.figure(figsize=(16, 5))
    fig.suptitle(title, fontsize=14, fontweight='bold', y=1.05)

    b = s['betas']
    x1_all = np.concatenate([s['x1t'], s['x1v']])
    x2_all = np.concatenate([s['x2t'], s['x2v']])
    y_all  = np.concatenate([s['yt'], s['yv']])
    ids_all = s['ids_t'] + s['ids_v']
    is_val_all = [False]*len(s['ids_t']) + [True]*len(s['ids_v'])

    # ---- clamp meshgrid ranges for kinetic predictors ---------------------
    def _axis_lim(col, arr):
        if col == 'inv_T':
            return SULFUR_INV_T_PLOT_LIM if s.get('is_sulfur') else INV_T_PLOT_LIM
        if col == 'ln_cycle': return LN_CYCLE_PLOT_LIM
        return (arr.min(), arr.max())
    x1_lo, x1_hi = _axis_lim(s.get('x1_col'), x1_all)
    x2_lo, x2_hi = _axis_lim(s.get('x2_col'), x2_all)
    # ------------------------------------------------------------------------

    # 1. 3D Surface
    ax1 = fig.add_subplot(1, 3, 1, projection='3d')
    X1G, X2G = np.meshgrid(np.linspace(x1_lo, x1_hi, 25), np.linspace(x2_lo, x2_hi, 25))
    YG_raw = b[0] + b[1]*X1G + b[2]*X2G
    YG = np.maximum(YG_raw, SULFUR_FLOOR) if s.get('is_sulfur') else YG_raw
    ax1.plot_surface(X1G, X2G, YG, cmap=cmap, alpha=0.3, linewidth=0)
    for i, lbl in enumerate(ids_all):
        sty = ORIGIN_STYLE.get(df.loc[lbl,'origin'], dict(color='grey', marker='o'))
        ys_raw = b[0] + b[1]*x1_all[i] + b[2]*x2_all[i]
        ys = max(ys_raw, SULFUR_FLOOR) if s.get('is_sulfur') else ys_raw
        val = is_val_all[i]
        ax1.plot([x1_all[i]]*2, [x2_all[i]]*2, [ys, y_all[i]], color=sty['color'], lw=1.2 if val else 0.5, alpha=0.8)
        ax1.scatter(x1_all[i], x2_all[i], y_all[i], color=sty['color'], marker=sty['marker'], s=80 if val else 30, edgecolors='black' if val else 'white', lw=1.0 if val else 0.5)
    ax1.set_xlabel(x1l, fontsize=9); ax1.set_ylabel(x2l, fontsize=9); ax1.set_zlabel(yl, fontsize=9)
    ax1.set_title("3D Regression Surface", fontsize=11)
    ax1.view_init(elev=24, azim=225)

    # 2. 2D Contour
    ax2 = fig.add_subplot(1, 3, 2)
    cf = ax2.contourf(X1G, X2G, YG, levels=20, cmap=cmap, alpha=0.5)
    plt.colorbar(cf, ax=ax2, label=yl)
    for i, lbl in enumerate(ids_all):
        sty = ORIGIN_STYLE.get(df.loc[lbl,'origin'], dict(color='grey', marker='o'))
        val = is_val_all[i]
        ax2.scatter(x1_all[i], x2_all[i], color=sty['color'], marker=sty['marker'], s=100 if val else 30, edgecolors='black' if val else 'white', lw=1.2 if val else 0.5)
    ax2.set_xlabel(x1l, fontsize=10); ax2.set_ylabel(x2l, fontsize=10)
    ax2.set_xlim(x1_lo, x1_hi); ax2.set_ylim(x2_lo, x2_hi)
    ax2.set_title("2D Contour Projection", fontsize=11)

    # --- ADDITION: secondary axes giving operator-interpretable T (°C) / t_c (h) ---
    x1c, x2c = s.get('x1_col'), s.get('x2_col')
    if x1c == 'inv_T':
        sx = ax2.secondary_xaxis('top', functions=(invT_to_C, C_to_invT))
        sx.set_xlabel('Real Temperature (°C)', fontsize=8, color='#c0392b')
        sx.tick_params(axis='x', labelsize=7, colors='#c0392b')
    elif x1c == 'ln_cycle':
        sx = ax2.secondary_xaxis('top', functions=(ln_to_h, h_to_ln))
        sx.set_xlabel('Real Cycle Time (h)', fontsize=8, color='#c0392b')
        sx.tick_params(axis='x', labelsize=7, colors='#c0392b')
    if x2c == 'inv_T':
        sy = ax2.secondary_yaxis('right', functions=(invT_to_C, C_to_invT))
        sy.set_ylabel('Real Temperature (°C)', fontsize=8, color='#c0392b')
        sy.tick_params(axis='y', labelsize=7, colors='#c0392b')
    elif x2c == 'ln_cycle':
        sy = ax2.secondary_yaxis('right', functions=(ln_to_h, h_to_ln))
        sy.set_ylabel('Real Cycle Time (h)', fontsize=8, color='#c0392b')
        sy.tick_params(axis='y', labelsize=7, colors='#c0392b')
    # ---------------------------------------------------------------------------

    # 3. Predicted vs Actual
    ax3 = fig.add_subplot(1, 3, 3)
    y_pred_raw = b[0] + b[1]*x1_all + b[2]*x2_all
    y_pred_all = np.maximum(y_pred_raw, SULFUR_FLOOR) if s.get('is_sulfur') else y_pred_raw
    lo, hi = min(y_all.min(), y_pred_all.min())*0.95, max(y_all.max(), y_pred_all.max())*1.05
    ax3.plot([lo, hi], [lo, hi], color='grey', ls='--', label='1:1')
    for i, lbl in enumerate(ids_all):
        sty = ORIGIN_STYLE.get(df.loc[lbl,'origin'], dict(color='grey', marker='o'))
        val = is_val_all[i]
        ax3.scatter(y_all[i], y_pred_all[i], color=sty['color'], marker=sty['marker'], s=100 if val else 35, edgecolors='black' if val else 'white', lw=1.2 if val else 0.5)
    ax3.set_xlim(lo, hi); ax3.set_ylim(lo, hi)
    ax3.set_aspect('equal', adjustable='box')
    ax3.set_xlabel(f"Observed {yl}", fontsize=10); ax3.set_ylabel(f"Predicted {yl}", fontsize=10)
    ax3.set_title("Predicted vs Actual (1:1)", fontsize=11)

    floor_note = '\n(predictions floored at S = 1 wt%)' if s.get('is_sulfur') else ''
    eq = (f"$\\hat{{y}} = {b[0]:.2f} + {b[1]:.4f}x_1 + {b[2]:.4f}x_2$"
          f"\nTrain R² = {s['r2']:.3f}   |   Val RMSE = {s['rmse_v']:.3f}{floor_note}")
    ax3.text(0.05, 0.95, eq, transform=ax3.transAxes, va='top', fontsize=9, bbox=dict(boxstyle='round', fc='white', alpha=0.9, ec='#ccc'))

    fig.legend(handles=legend_handles(), loc='lower center', ncol=8, bbox_to_anchor=(0.5, -0.05), fontsize=10, title='Feed Geographic Origin (Validation highlighted bold)')
    plt.tight_layout(rect=[0, 0.05, 1, 0.95])
    plt.show()

SURFACE_SPECS = [
    ('density',  'ccr',      'coke_yld', 'Density (kg/m³)', 'CCR (wt%)', 'Coke Yield (wt%)', 'Density + CCR -> Coke Yield', 'viridis'),
    ('s_feed',   'ln_cycle', 'coke_s',   'Feed S (wt%)', 'ln(t)', 'Coke Sulfur (wt%)', 'Feed Sulfur + ln(Cycle) -> Coke Sulfur', 'magma'),
    ('inv_T',    'ln_cycle', 'coke_yld', '1000/T (x10⁻³ K⁻¹)', 'ln(t)', 'Coke Yield (wt%)', '1/T + ln(Cycle) -> Coke Yield (KINETIC)', 'plasma'),
    ('c_wt',     'v_ppm',    'coke_yld', 'Carbon (wt%)', 'Vanadium (ppm)', 'Coke Yield (wt%)', 'Feed Carbon + Vanadium -> Coke Yield', 'cividis'),
]

print("Generating Multivariate 3D/2D Trio Figures...")
# Note: Figures 4 and 5 are now Coke Carbon (feed-quality + kinetic) regressions,
# so the 3D multivariate trio panels start at Figure 6 to keep numbering contiguous.
for idx, (x1c, x2c, yc, x1l, x2l, yl, base_title, cmap) in enumerate(SURFACE_SPECS, start=6):
    s = fit_surface(x1c, x2c, yc)
