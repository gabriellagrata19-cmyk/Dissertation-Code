    print(f"  Linearised Arrhenius:  ln(Y) = {intercept:.3f} + ({slope:.3f})·(1000/T)")
    print(f"  Apparent Ea (kJ/mol)  = -slope · R = {Ea_app_kJ:.2f}  kJ/mol")
    print(f"  Pre-exponential ln(A) = {intercept:.3f}")
    print( "  Note: Ea_app is a population-weighted average over SARA-fraction pathways")
    print( "        plus operator-severity confounding (heavier feeds run cooler).")

# ==========================================================================
# SECTION 13 — OPERATIONAL OPTIMISATION (per-feed scenarios)
# ==========================================================================
_section("13.0  OPERATIONAL OPTIMISATION — per-feed scenarios")

def _fit_linear(cols, resp):
    valid = TRAIN.copy()
    for c in cols + [resp]:
        valid &= df[c].notna()
    Xtr = df.loc[valid, cols].values
    ytr = df.loc[valid, resp].values
    A = np.column_stack([np.ones(len(ytr)), Xtr])
    beta, *_ = np.linalg.lstsq(A, ytr, rcond=None)
    yp = A @ beta
    r2 = 1 - np.sum((ytr-yp)**2)/max(np.sum((ytr-ytr.mean())**2), 1e-14)
    return beta, r2, len(ytr)

YIELD_COLS = ['density', 's_feed', 'inv_T', 'ln_cycle']
SULF_COLS  = ['s_feed',  'v_ppm', 'inv_T', 'ln_cycle']
CARB_COLS  = ['ccr', 'v_ppm', 'ni_ppm']

bY, r2Y, nY = _fit_linear(YIELD_COLS, 'coke_yld')
bS, r2S, nS = _fit_linear(SULF_COLS,  'coke_s')
bC, r2C, nC = _fit_linear(CARB_COLS,  'coke_c_wt')

print("Surrogate models fitted on training set:")
print(f"  Yield  (n={nY}, R²={r2Y:.3f}): coke_yld = {bY[0]:.3f}"
      + ''.join([f" + ({b:+.5f})·{c}" for b,c in zip(bY[1:], YIELD_COLS)]))
print(f"  Sulfur (n={nS}, R²={r2S:.3f}): coke_s   = {bS[0]:.3f}"
      + ''.join([f" + ({b:+.5f})·{c}" for b,c in zip(bS[1:], SULF_COLS)]))
print(f"  Carbon (n={nC}, R²={r2C:.3f}): coke_c   = {bC[0]:.3f}"
      + ''.join([f" + ({b:+.5f})·{c}" for b,c in zip(bC[1:], CARB_COLS)]))
print(f"\n  >>> Sulfur predictions clipped at coke_s >= {SULFUR_FLOOR} wt% (physical floor) <<<")

T_LO, T_HI       = 440.0, 510.0
CYC_LO, CYC_HI   = 16.0, 36.0
S_ANODE_MAX      = 3.5
C_ANODE_MIN      = 90.0
W_YIELD, W_SULF  = 1.0, 2.0
PEN_S, PEN_C     = 1000.0, 1000.0

def _yield_pred(feed, T, tc):
    inv_T   = 1000.0/(T+273.15)
    ln_t    = np.log(tc)
    vec = {'density': feed['density'], 's_feed': feed['s_feed'],
           'inv_T': inv_T, 'ln_cycle': ln_t}
    return bY[0] + sum(bY[i+1]*vec[c] for i,c in enumerate(YIELD_COLS))

def _sulf_pred(feed, T, tc):
    """Predicted coke sulfur — FLOORED at SULFUR_FLOOR (1 wt%).

    The OLS surrogate is a linear extrapolator and can return unphysically
    low (or negative) values for sweet feeds outside the training envelope.
    Industrial petroleum coke from delayed coking carries residual organic
    sulfur from the resin/asphaltene fraction; literature surveys put the
    practical floor at ~1 wt% even for sweet feeds (Edwards 2014, Predel
    2014).  We therefore clip every sulfur prediction:
            S_pred = max( S_OLS , SULFUR_FLOOR )
    This change directly addresses the reviewer's note about 0% sulfur
    predictions in the optimisation outputs.
    """
    inv_T = 1000.0/(T+273.15); ln_t = np.log(tc)
    vec = {'s_feed': feed['s_feed'], 'v_ppm': feed['v_ppm'],
           'inv_T': inv_T, 'ln_cycle': ln_t}
    raw = bS[0] + sum(bS[i+1]*vec[c] for i,c in enumerate(SULF_COLS))
    return max(float(raw), SULFUR_FLOOR)

def _sulf_pred_raw(feed, T, tc):
    """Un-floored sulfur prediction (for diagnostic comparison only)."""
    inv_T = 1000.0/(T+273.15); ln_t = np.log(tc)
    vec = {'s_feed': feed['s_feed'], 'v_ppm': feed['v_ppm'],
           'inv_T': inv_T, 'ln_cycle': ln_t}
    return float(bS[0] + sum(bS[i+1]*vec[c] for i,c in enumerate(SULF_COLS)))

def _carb_pred(feed):
    vec = {'ccr': feed['ccr'], 'v_ppm': feed['v_ppm'], 'ni_ppm': feed['ni_ppm']}
    return bC[0] + sum(bC[i+1]*vec[c] for i,c in enumerate(CARB_COLS))

def _objective(x, feed):
    T, tc = x
    Y = _yield_pred(feed, T, tc)
    S = _sulf_pred(feed, T, tc)        # already floored
    C = _carb_pred(feed)
    f = -W_YIELD*Y + W_SULF*S
    f += PEN_S * max(0.0, S - S_ANODE_MAX)**2
    f += PEN_C * max(0.0, C_ANODE_MIN - C)**2
    return f

def _optimise(feed):
    bounds = [(T_LO, T_HI), (CYC_LO, CYC_HI)]
    result = differential_evolution(
        _objective, bounds, args=(feed,),
        maxiter=400, popsize=20, tol=1e-9,
        mutation=(0.5,1.5), recombination=0.9, seed=42)
    T_opt, tc_opt = result.x
    Y     = _yield_pred(feed, T_opt, tc_opt)
    S     = _sulf_pred(feed, T_opt, tc_opt)        # floored
    S_raw = _sulf_pred_raw(feed, T_opt, tc_opt)    # un-floored, for transparency
    C     = _carb_pred(feed)
    return T_opt, tc_opt, Y, S, S_raw, C

SCENARIOS = [
    ("Statfjord-type (Norway, light/sweet)",
        dict(density=985.0,  ccr=12.2, s_feed=0.42, v_ppm=12,  ni_ppm=4)),
    ("Anqing-type (China, low S)",
        dict(density=1019.9, ccr=14.35,s_feed=1.04, v_ppm=45,  ni_ppm=15)),
    ("US Mid-cont (medium)",
        dict(density=1005.0, ccr=14.0, s_feed=1.80, v_ppm=35,  ni_ppm=12)),
    ("Abadan-type (Iran, medium-high S)",
        dict(density=1022.0, ccr=21.0, s_feed=3.50, v_ppm=95,  ni_ppm=35)),
    ("Athabasca-type (Canadian bitumen, heavy)",
        dict(density=1045.0, ccr=23.5, s_feed=4.80, v_ppm=210, ni_ppm=85)),
    ("Orinoco-type (Venezuelan extra-heavy)",
        dict(density=1055.0, ccr=25.0, s_feed=5.20, v_ppm=350, ni_ppm=110)),
]

print()
print(f"Constraints: T in [{T_LO}, {T_HI}] °C, cycle in [{CYC_LO}, {CYC_HI}] h")
print(f"Anode-grade joint spec: S <= {S_ANODE_MAX} wt%  AND  C >= {C_ANODE_MIN} wt%")
print(f"Sulfur floor enforced:  S_pred = max(S_OLS, {SULFUR_FLOOR} wt%)")
print(f"Objective: min  -{W_YIELD}·Y + {W_SULF}·S  + penalty·max(0, S-{S_ANODE_MAX})²"
      f"  + penalty·max(0,{C_ANODE_MIN}-C)²")
print()

opt_records = []
for name, feed in SCENARIOS:
    T_opt, tc_opt, Y, S, S_raw, C = _optimise(feed)
    s_ok = "OK" if S <= S_ANODE_MAX else "FAIL"
    c_ok = "OK" if C >= C_ANODE_MIN else "FAIL"
    grade = "ANODE-GRADE FEASIBLE" if (S <= S_ANODE_MAX and C >= C_ANODE_MIN) \
            else "FAILS ANODE-GRADE — pretreatment required"
    floored_note = "  <-- FLOOR ACTIVE" if S_raw < SULFUR_FLOOR else ""
    print(f"-- {name} --")
    print(f"     Optimal T       : {T_opt:6.2f}  C")
    print(f"     Optimal cycle   : {tc_opt:6.2f}  h")
    print(f"     Yield (pred)    : {Y:6.2f}  wt%")
    print(f"     Coke S (raw OLS): {S_raw:6.3f}  wt%{floored_note}")
    print(f"     Coke S (final)  : {S:6.3f}  wt%   ({s_ok}, ceiling {S_ANODE_MAX}%, floor {SULFUR_FLOOR}%)")
    print(f"     Coke C (pred)   : {C:6.2f}  wt%   ({c_ok}, floor   {C_ANODE_MIN}%)")
    print(f"     Grade verdict   : {grade}")
    print()
    opt_records.append(dict(scenario=name, T_opt=T_opt, tc_opt=tc_opt,
                            yield_pred=Y, sulfur_pred=S, sulfur_raw=S_raw,
                            sulfur_floored=(S_raw < SULFUR_FLOOR),
                            carbon_pred=C,
                            anode_feasible=(S<=S_ANODE_MAX and C>=C_ANODE_MIN)))

print("="*92)
print("13.4  OPTIMISATION SUMMARY TABLE")
print("="*92)
print(f"{'Scenario':<42}{'T_opt':>8}{'t_opt':>8}{'Y':>8}{'S_raw':>8}{'S':>8}{'C':>8}  Verdict")
print('-'*92)
for r in opt_records:
    v = "ANODE OK" if r['anode_feasible'] else "FAIL"
    flr = "*" if r['sulfur_floored'] else " "
    print(f"{r['scenario']:<42}{r['T_opt']:>8.2f}{r['tc_opt']:>8.2f}"
          f"{r['yield_pred']:>8.2f}{r['sulfur_raw']:>8.3f}{r['sulfur_pred']:>7.3f}{flr}{r['carbon_pred']:>8.2f}  {v}")
print("\n  Asterisk (*) flags scenarios where the un-floored OLS sulfur prediction")
print(f"  was below the {SULFUR_FLOOR} wt% physical floor and therefore clipped.")

try:
    pd.DataFrame(univariate_records).to_csv('univariate_diagnostics.csv', index=False)
    pd.DataFrame(opt_records).to_csv('optimisation_results.csv', index=False)
    print("\nMachine-readable outputs saved:")
