_section("12.7  MULTIVARIATE OLS SURFACES — Diagnostics")
print(f"{'Surface':<48}{'n':>3} {'R²':>7} {'adjR²':>7} "
      f"{'F':>9} {'p(F)':>9} {'AICc':>8} {'BIC':>8} {'RMSE_V':>8} {'RMSE_N':>8}")
print('-'*92 + '-'*30)
for (x1c,x2c,yc,x1l,x2l,yl,title,cmap) in SURFACE_SPECS:
    s = fit_surface(x1c, x2c, yc)
    yp_t = s['betas'][0] + s['betas'][1]*s['x1t'] + s['betas'][2]*s['x2t']
    ext = _extended_ic(s['yt'], yp_t, k=3)
    rmse_ven = rmse_nor = np.nan
    if len(s['x1v']) > 0:
        yv_p_raw = s['betas'][0] + s['betas'][1]*s['x1v'] + s['betas'][2]*s['x2v']
        yv_p = apply_floor_if_sulfur(yv_p_raw, yc)
        origins_v = [df.loc[i,'origin'] for i in s['ids_v']]
        ven_mask = np.array([o == 'Venezuela' for o in origins_v])
        nor_mask = np.array([o == 'Norway'    for o in origins_v])
        if ven_mask.any(): rmse_ven = float(np.sqrt(np.mean((s['yv'][ven_mask]-yv_p[ven_mask])**2)))
        if nor_mask.any(): rmse_nor = float(np.sqrt(np.mean((s['yv'][nor_mask]-yv_p[nor_mask])**2)))
    def _f(x, w=8, p=3):
        if x is None or (isinstance(x,float) and np.isnan(x)): return f"{'-':>{w}}"
        return f"{x:>{w}.{p}f}"
    name = f"{x1c}+{x2c} -> {yc}"
    print(f"{name:<48}{ext['n']:>3} {ext['r2']:>7.3f} {ext['adjR2']:>7.3f} "
          f"{ext['F']:>9.2f} {ext['pF']:>9.4f} "
          f"{_f(ext['aicc'])} {_f(ext['bic'])} {_f(rmse_ven)} {_f(rmse_nor)}")
    n = len(s['x1t']); thr = 4.0/n
    Xm = np.column_stack([np.ones(n), s['x1t'], s['x2t']])
    H = Xm @ np.linalg.pinv(Xm.T @ Xm) @ Xm.T
    h = np.diag(H)
    e = s['yt'] - yp_t
    s2 = max(np.sum(e**2)/max(n-3,1), 1e-14)
    D = (e**2/(3*s2)) * (h/(1-h)**2)
    flagged = [(s['ids_t'][i], D[i]) for i in range(n) if D[i] > thr]
    flagged.sort(key=lambda t: -t[1])
    flag_str = ',  '.join([f"{lbl}:{d:.3f}" for lbl,d in flagged]) if flagged else '(none)'
    print(f"   Cook's D (thr={thr:.3f}): {flag_str}")
    print(f"   Fitted: ŷ = {s['betas'][0]:.3f} + {s['betas'][1]:.5f}·{x1c} + {s['betas'][2]:.5f}·{x2c}")
    if is_sulfur_response(yc):
        print(f"   (Predictions clipped at coke_s >= {SULFUR_FLOOR} wt%.)")
    print()

