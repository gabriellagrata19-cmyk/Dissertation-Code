# ==========================================================================
# SECTION 3 & 4 — CURVE FITTING ENGINE
# ==========================================================================
def ic(y_obs, y_pred, k):
    n   = len(y_obs)
    rss = np.sum((np.asarray(y_obs) - np.asarray(y_pred))**2)
    s2  = max(rss / n, 1e-14)
    ll  = -n/2 * (np.log(2*np.pi*s2) + 1)
    aic  = 2*k - 2*ll
    bic  = k*np.log(n) - 2*ll
    aicc = aic + (2*k*(k+1))/(n-k-1) if n > k+2 else np.nan
    r2   = 1 - rss/max(np.sum((y_obs-y_obs.mean())**2), 1e-14)
    return dict(aic=aic, bic=bic, aicc=aicc, r2=r2, rss=rss)

def fit_best(x_col, y_col, x_phys, y_label):
    valid  = df[x_col].notna() & df[y_col].notna()
    t_mask = valid & TRAIN
    v_mask = valid & VAL
    xt = df.loc[t_mask, x_col].values.astype(float)
    yt = df.loc[t_mask, y_col].values.astype(float)
    xv = df.loc[v_mask, x_col].values.astype(float)
    yv = df.loc[v_mask, y_col].values.astype(float)

    if len(xt) < 3: return None
    forms = []

    # 1. Linear
    try:
        c  = np.polyfit(xt, yt, 1)
        forms.append(dict(name='linear', coeffs=c, yp=np.polyval(c, xt), eq=f"y = {c[1]:.2f} + {c[0]:.3f}*x", k=2, **ic(yt, np.polyval(c, xt), 2)))
    except: pass

    # 2. Quad
    if len(xt) >= 5:
        try:
            c  = np.polyfit(xt, yt, 2)
            forms.append(dict(name='quadratic', coeffs=c, yp=np.polyval(c, xt), eq=f"y = {c[2]:.2f} + {c[1]:.3f}*x + {c[0]:.4f}*x²", k=3, **ic(yt, np.polyval(c, xt), 3)))
        except: pass

    # 3. Log
    if np.all(xt > 0):
        try:
            c  = np.polyfit(np.log(xt), yt, 1)
            yp = c[1] + c[0]*np.log(xt)
            forms.append(dict(name='logarithmic', coeffs=c, yp=yp, eq=f"y = {c[1]:.2f} + {c[0]:.3f}*ln(x)", k=2, **ic(yt, yp, 2)))
        except: pass

    # 4. Exponential
    if np.all(yt > 0):
        try:
            p, _ = curve_fit(lambda x, a, b: a*np.exp(b*x), xt, yt, p0=[yt.mean(), 0.01], maxfev=8000)
            yp   = p[0]*np.exp(p[1]*xt)
            forms.append(dict(name='exponential', coeffs=p, yp=yp, eq=f"y = {p[0]:.2f}*exp({p[1]:.3f}*x)", k=2, **ic(yt, yp, 2)))
        except: pass

    if not forms: return None

    forms.sort(key=lambda f: f['aicc'] if not np.isnan(f['aicc']) else f['aic'])
    best = forms[0]

    rmse_v = np.nan
    if len(xv) > 0:
        yv_pred = _eval_form(xv, best['name'], best['coeffs'], y_col=y_col)
        rmse_v  = np.sqrt(np.mean((yv - yv_pred)**2))

    return dict(xt=xt, yt=yt, ids_t=df.index[t_mask].tolist(),
                xv=xv, yv=yv, ids_v=df.index[v_mask].tolist(),
                best=best, all_forms=forms, x_col=x_col, y_col=y_col,
                x_phys=x_phys, y_label=y_label, rmse_v=rmse_v,
                is_sulfur=is_sulfur_response(y_col))

def _eval_form(x, name, coeffs, y_col=None):
    """Evaluate fitted form. If y_col is the sulfur response, floor predictions at SULFUR_FLOOR."""
    if name == 'linear':        y = np.polyval(coeffs, x)
    elif name == 'quadratic':   y = np.polyval(coeffs, x)
    elif name == 'logarithmic': y = coeffs[1] + coeffs[0]*np.log(x)
    elif name == 'exponential': y = coeffs[0]*np.exp(coeffs[1]*x)
    else:                       return None
    return apply_floor_if_sulfur(y, y_col) if y_col is not None else y

def _pi(x_fit, x_t, y_t, yp_t, k, alpha=0.05):
    n   = len(x_t)
    s2  = np.sum((y_t - yp_t)**2) / max(n - k, 1)
    return t_dist.ppf(1-alpha/2, df=n-k) * np.sqrt(s2*(1 + 1/n + (x_fit-x_t.mean())**2/max(np.sum((x_t - x_t.mean())**2),1e-12)))


# ==========================================================================
# SECTION 5 — 2D PLOTTING LOGIC (Cleaned Info Boxes & Dual Axes)
# ==========================================================================
def draw_train(res, ax, xlim=None, ylim=None):
    if res is None: ax.set_visible(False); return
    xt, yt, best = res['xt'], res['yt'], res['best']

    # ---- enforce sensible operator window for kinetic predictors -----------
    if xlim is None and res['x_col'] == 'inv_T':
        xlim = SULFUR_INV_T_PLOT_LIM if res.get('is_sulfur') else INV_T_PLOT_LIM
    if xlim is None and res['x_col'] == 'ln_cycle':    xlim = LN_CYCLE_PLOT_LIM
    # ------------------------------------------------------------------------

    lo, hi = (xlim[0], xlim[1]) if xlim else (xt.min() - 0.04*(xt.max()-xt.min()), xt.max() + 0.04*(xt.max()-xt.min()))
    xr = np.linspace(max(lo, 1e-6) if best['name'] in ('logarithmic','exponential') else lo, hi, 300)
    yr = _eval_form(xr, best['name'], best['coeffs'], y_col=res.get('y_col'))

    # residual std (visible quantity that drives PI band width)
    n = len(xt); k = best['k']
    s_resid = float(np.sqrt(np.sum((yt - best['yp'])**2) / max(n - k, 1)))

    if yr is not None:
        pi_half = _pi(xr, xt, yt, best['yp'], best['k'])
        lo_band = yr - pi_half
        hi_band = yr + pi_half
        # floor lower band of PI for sulfur (no estimation < SULFUR_FLOOR)
        if res.get('is_sulfur'):
            lo_band = np.maximum(lo_band, SULFUR_FLOOR)
        ax.fill_between(xr, lo_band, hi_band, color='#2c3e50', alpha=0.10)
        ax.plot(xr, yr, color='#2c3e50', lw=2.0, zorder=6)

    for j, lbl in enumerate(res['ids_t']):
        sty = ORIGIN_STYLE.get(df.loc[lbl,'origin'], dict(color='grey', marker='o'))
        ax.scatter(xt[j], yt[j], color=sty['color'], marker=sty['marker'], s=55, zorder=7, edgecolors='white', lw=0.6)
        ax.annotate(lbl, (xt[j], yt[j]), xytext=(3,3), textcoords='offset points', fontsize=6.5, color=sty['color'])

    # Cleaned Text Box — now exposes s_resid (PI band drivers are transparent)
    ax.text(0.03, 0.97,
            f"Best: {best['name']}\n{best['eq']}\nR² = {best['r2']:.3f}   s = {s_resid:.3f}",
            transform=ax.transAxes, fontsize=8, va='top',
            bbox=dict(boxstyle='round,pad=0.3', facecolor='white', ec='#ccc', alpha=0.9))

    # if sulfur response, draw a faint horizontal line at the floor
    if res.get('is_sulfur'):
        ax.axhline(SULFUR_FLOOR, color='#7f8c8d', lw=0.8, ls=':', alpha=0.7, zorder=3)

    ax.set_xlabel(res['x_phys'], fontsize=9); ax.set_ylabel(res['y_label'], fontsize=9)
    ax.set_title(f"TRAIN: {res['x_phys']} -> {res['y_label']}", fontsize=10, fontweight='bold', color='#2c3e50')
    if xlim: ax.set_xlim(xlim)
    if ylim: ax.set_ylim(ylim)

    # ADD DUAL X-AXIS FOR OPERATORS
    if res['x_col'] == 'inv_T':
        secax = ax.secondary_xaxis('top', functions=(invT_to_C, C_to_invT))
        secax.set_xlabel('Real Temperature (°C)', fontsize=8, color='#c0392b')
        secax.tick_params(axis='x', labelsize=7, colors='#c0392b')
    elif res['x_col'] == 'ln_cycle':
        secax = ax.secondary_xaxis('top', functions=(ln_to_h, h_to_ln))
        secax.set_xlabel('Real Cycle Time (h)', fontsize=8, color='#c0392b')
        secax.tick_params(axis='x', labelsize=7, colors='#c0392b')


def draw_val(res, ax, xlim=None, ylim=None):
    if res is None: ax.set_visible(False); return
    xt, yt, xv, yv, best = res['xt'], res['yt'], res['xv'], res['yv'], res['best']

    # ---- enforce sensible operator window for kinetic predictors -----------
    if xlim is None and res['x_col'] == 'inv_T':
        xlim = SULFUR_INV_T_PLOT_LIM if res.get('is_sulfur') else INV_T_PLOT_LIM
    if xlim is None and res['x_col'] == 'ln_cycle':    xlim = LN_CYCLE_PLOT_LIM
    # ------------------------------------------------------------------------

    lo, hi = (xlim[0], xlim[1]) if xlim else (
        np.concatenate([xt, xv]).min() - 0.04*(np.concatenate([xt, xv]).max() - np.concatenate([xt, xv]).min()),
        np.concatenate([xt, xv]).max() + 0.04*(np.concatenate([xt, xv]).max() - np.concatenate([xt, xv]).min()))
    xr = np.linspace(max(lo, 1e-6) if best['name'] in ('logarithmic','exponential') else lo, hi, 300)
    yr = _eval_form(xr, best['name'], best['coeffs'], y_col=res.get('y_col'))

    if yr is not None:
        pi_half = _pi(xr, xt, yt, best['yp'], best['k'])
        lo_band = yr - pi_half
        hi_band = yr + pi_half
        if res.get('is_sulfur'):
            lo_band = np.maximum(lo_band, SULFUR_FLOOR)
        ax.fill_between(xr, lo_band, hi_band, color='#2c3e50', alpha=0.10)
        ax.plot(xr, yr, color='#2c3e50', lw=1.8, ls='--', alpha=0.85)

    if len(xv) > 0:
        for j, lbl in enumerate(res['ids_v']):
            sty = ORIGIN_STYLE.get(df.loc[lbl,'origin'], dict(color='grey', marker='o'))
            ax.scatter(xv[j], yv[j], color=sty['color'], marker=sty['marker'], s=130 if sty['marker']=='*' else 100, zorder=7, edgecolors='black', linewidths=1.0)
            ax.annotate(lbl, (xv[j], yv[j]), xytext=(5,5), textcoords='offset points', fontsize=8, fontweight='bold', color=sty['color'])

    # Cleaned Text Box (Validation)
    rmse_str = f"{res['rmse_v']:.3f}" if not np.isnan(res['rmse_v']) else '-'
    ax.text(0.03, 0.97, f"Overall Val RMSE = {rmse_str}", transform=ax.transAxes, fontsize=8, va='top', bbox=dict(boxstyle='round,pad=0.3', facecolor='#fdfefe', ec='#c0392b', alpha=0.9))

    if res.get('is_sulfur'):
        ax.axhline(SULFUR_FLOOR, color='#7f8c8d', lw=0.8, ls=':', alpha=0.7, zorder=3)

    ax.set_xlabel(res['x_phys'], fontsize=9); ax.set_ylabel(res['y_label'], fontsize=9)
    ax.set_title(f"VALIDATION (Venezuela + Norway)", fontsize=10, fontweight='bold', color='#c0392b')
    if xlim: ax.set_xlim(xlim)
    if ylim: ax.set_ylim(ylim)

    # ADD DUAL X-AXIS FOR OPERATORS
    if res['x_col'] == 'inv_T':
        secax = ax.secondary_xaxis('top', functions=(invT_to_C, C_to_invT))
        secax.set_xlabel('Real Temperature (°C)', fontsize=8, color='#c0392b')
        secax.tick_params(axis='x', labelsize=7, colors='#c0392b')
    elif res['x_col'] == 'ln_cycle':
        secax = ax.secondary_xaxis('top', functions=(ln_to_h, h_to_ln))
        secax.set_xlabel('Real Cycle Time (h)', fontsize=8, color='#c0392b')
        secax.tick_params(axis='x', labelsize=7, colors='#c0392b')


def make_figure(specs, fig_title, nrows):
    fig, axes = plt.subplots(nrows, 2, figsize=(14, nrows*4.5))
    if nrows == 1: axes = axes.reshape(1, 2)
    fig.suptitle(fig_title, fontsize=14, fontweight='bold', y=1.02)
    for row, spec in enumerate(specs):
        res = fit_best(spec[0], spec[1], spec[2], spec[3])
        draw_train(res, axes[row, 0], xlim=spec[4] if len(spec)>4 else None, ylim=spec[5] if len(spec)>5 else None)
        draw_val(res,   axes[row, 1], xlim=spec[4] if len(spec)>4 else None, ylim=spec[5] if len(spec)>5 else None)
    fig.legend(handles=legend_handles(), loc='lower center', ncol=8, bbox_to_anchor=(0.5, -0.02), fontsize=9, title='Feed Geographic Origin (Validation highlighted bold)', title_fontsize=10)
    plt.tight_layout(rect=[0, 0.04, 1, 0.98])
    plt.show()

