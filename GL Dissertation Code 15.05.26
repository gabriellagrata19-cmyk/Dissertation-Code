import itertools

def _hr(c='='): print(c*92)
def _section(t):
    print(); _hr('='); print(t); _hr('=')

PREDICTORS_FEED = ['density', 'ccr', 's_feed', 'c_wt', 'v_ppm', 'ni_ppm']
PREDICTORS_OPER = ['inv_T', 'ln_cycle']
PREDICTORS_ALL  = PREDICTORS_FEED + PREDICTORS_OPER
RESPONSES       = ['coke_yld', 'coke_s', 'coke_c_wt']

PRED_LABEL = {
    'density':  'Density (kg/m³)',
    'ccr':      'CCR (wt%)',
    's_feed':   'Feed S (wt%)',
    'c_wt':     'Feed C (wt%)',
    'v_ppm':    'V (ppm)',
    'ni_ppm':   'Ni (ppm)',
    'inv_T':    '1000/T (1/K)',
    'ln_cycle': 'ln(t_c)',
}
RESP_LABEL = {
    'coke_yld':  'Coke Yield (wt%)',
    'coke_s':    'Coke Sulfur (wt%)',
    'coke_c_wt': 'Coke Carbon (wt%, derived)',
}

def _extended_ic(y_obs, y_pred, k):
    n   = len(y_obs)
    rss = float(np.sum((y_obs - y_pred)**2))
    s2  = max(rss/n, 1e-14)
    ll  = -n/2 * (np.log(2*np.pi*s2) + 1)
    aic  = 2*k - 2*ll
    bic  = k*np.log(n) - 2*ll
    aicc = aic + (2*k*(k+1))/(n-k-1) if n > k+2 else np.nan
    hqc  = 2*k*np.log(np.log(max(n,3))) - 2*ll
    tss  = float(np.sum((y_obs - y_obs.mean())**2))
    r2   = 1 - rss/max(tss, 1e-14)
    adjR2 = 1 - (1-r2)*(n-1)/max(n-k, 1)
    df1, df2 = max(k-1,1), max(n-k, 1)
    msr = (tss - rss) / df1
    mse = rss / df2
    F   = msr/mse if mse > 0 else np.nan
    pF  = 1 - f_dist.cdf(F, df1, df2) if not np.isnan(F) else np.nan
    return dict(n=n, k=k, rss=rss, r2=r2, adjR2=adjR2,
                aic=aic, aicc=aicc, bic=bic, hqc=hqc,
                F=F, pF=pF, df1=df1, df2=df2)

# ==========================================================================
# 12.0  PREDICTION-INTERVAL DIAGNOSTIC TABLE (NEW)
# ==========================================================================
# Quantifies why the shaded region varies in width.  PI half-width depends on:
#     PI(x) = t_{α/2,n-k} * s * sqrt( 1 + 1/n + (x-x̄)²/Sxx )
# where  s     = residual std error  (LARGER when fit is noisier)
#        n     = training sample size
#        Sxx   = Σ(x_t - x̄)²       (LARGER when training spans wider x-range)
#        t_*   = Student-t critical (LARGER for small n)
# ==========================================================================
_section("12.0  PREDICTION-INTERVAL WIDTH AUDIT (drives the shaded-region size)")
print(f"{'Predictor':<14}{'Response':<22}{'Form':<13}"
      f"{'n':>3} {'s_resid':>9} {'Sxx':>10} {'t_crit':>8} "
      f"{'PI_at_xbar':>11} {'PI_at_edge':>11}")
print('-'*96)
for pred in PREDICTORS_ALL:
    for resp in RESPONSES:
        res = fit_best(pred, resp, PRED_LABEL[pred], RESP_LABEL[resp])
        if res is None: continue
        b = res['best']
        n = len(res['xt']); k = b['k']
        s_resid = float(np.sqrt(np.sum((res['yt'] - b['yp'])**2) / max(n - k, 1)))
        xbar = float(res['xt'].mean())
        Sxx  = float(np.sum((res['xt'] - xbar)**2))
        t_crit = float(t_dist.ppf(0.975, df=max(n - k, 1)))
        # PI half-width at the centroid (minimum width)
        pi_min = t_crit * s_resid * np.sqrt(1 + 1.0/n)
        # PI half-width at the data edge (maximum within data)
        x_edge = max(abs(res['xt'].max() - xbar), abs(res['xt'].min() - xbar))
        pi_max = t_crit * s_resid * np.sqrt(1 + 1.0/n + x_edge**2/max(Sxx, 1e-12))
        print(f"{pred:<14}{resp:<22}{b['name']:<13}"
              f"{n:>3} {s_resid:>9.3f} {Sxx:>10.3f} {t_crit:>8.3f} "
              f"{pi_min:>11.3f} {pi_max:>11.3f}")
print()
print("Interpretation:")
print("  • s_resid is the dominant driver: large residual std -> wide shaded band.")
print("  • Small Sxx (predictor narrow on training set) inflates the leverage term")
print("    PI(x_edge), so plots whose training x-range is narrow look wider far from x̄.")
print("  • Bands look TIGHT for fits with small s_resid (e.g., density -> coke_yld);")
print("    they look WIDE for fits with high noise (e.g., ln_cycle -> coke_yld) AND")
print("    wherever the prediction point is far from the training centroid.")
print("  • For sulfur responses, the lower edge of the band is clipped at "
      f"S = {SULFUR_FLOOR} wt% (physical floor); the band cannot extend below it.")

