# ==========================================================================
# SECTION 13B — PARETO FRONT ANALYSIS
# ==========================================================================

import numpy as np
import matplotlib.pyplot as plt
import matplotlib.patches as mpatches
from matplotlib.lines import Line2D

# --------------------------------------------------------------------------
# 13B.0  Grid sampling of (T, t_c) space
# --------------------------------------------------------------------------


N_T   = 80
N_CYC = 80
T_GRID   = np.linspace(T_LO,   T_HI,   N_T)
CYC_GRID = np.linspace(CYC_LO, CYC_HI, N_CYC)

TG, CG = np.meshgrid(T_GRID, CYC_GRID)          # shapes (N_CYC, N_T)
T_FLAT  = TG.ravel()
CYC_FLAT = CG.ravel()


def _grid_evaluate(feed):
    """Evaluate yield and sulfur at every (T, t_c) grid point for one feed."""
    Y = np.array([_yield_pred(feed, T, tc) for T, tc in zip(T_FLAT, CYC_FLAT)])
    S = np.array([_sulf_pred(feed, T, tc)  for T, tc in zip(T_FLAT, CYC_FLAT)])
    C = float(_carb_pred(feed))   # feed-only, no operating-variable dependence
    return Y, S, C


def _pareto_filter(Y, S):
    """
    Return boolean mask of non-dominated points.
    Non-dominated: no other point has Y_j >= Y_i AND S_j <= S_i
                   with at least one strict inequality.
    Direction: maximise Y, minimise S.
    """
    n = len(Y)
    dominated = np.zeros(n, dtype=bool)
    for i in range(n):
        # Any j that dominates i?
        # j dominates i  iff  Y[j]>=Y[i] AND S[j]<=S[i] AND (Y[j]>Y[i] OR S[j]<S[i])
        dom_Y = Y >= Y[i]
        dom_S = S <= S[i]
        strict = (Y > Y[i]) | (S < S[i])
        if np.any(dom_Y & dom_S & strict & (np.arange(n) != i)):
            dominated[i] = True
    return ~dominated


# --------------------------------------------------------------------------
# 13B.1  Compute Pareto fronts for all scenarios
# --------------------------------------------------------------------------

# Colour palette for Pareto curves — distinct from ORIGIN_STYLE to avoid
# confusion; these are scenario curves, not per-origin data points.
SCENARIO_COLOURS = [
    '#2980b9',  # Statfjord (light blue)
    '#27ae60',  # Anqing (green)
    '#f39c12',  # US Mid-cont (amber)
    '#e74c3c',  # Abadan (red)
    '#8e44ad',  # Athabasca (purple)
    '#1abc9c',  # Orinoco (teal)
]

pareto_results = []

print()
print("="*92)
print("13B.1  PARETO FRONT COMPUTATION — Yield vs Sulfur, feasible (T, t_c) space")
print("="*92)
print(f"Grid: {N_T} T-points × {N_CYC} cycle-points = {N_T*N_CYC} candidates per scenario")
print(f"Operating window: T ∈ [{T_LO}, {T_HI}] °C  |  t_c ∈ [{CYC_LO}, {CYC_HI}] h")
print(f"Anode ceiling (S): {S_ANODE_MAX} wt%")
print(f"Anode floor   (C): {C_ANODE_MIN} wt%")
print()
print(f"{'Scenario':<42}{'n_front':>8}{'Y_min':>8}{'Y_max':>8}"
      f"{'S_min':>8}{'S_max':>8}{'C_pred':>8}  Feasibility")
print('-'*92)

for (name, feed), colour in zip(SCENARIOS, SCENARIO_COLOURS):
    Y_all, S_all, C_pred = _grid_evaluate(feed)

    # Non-dominated mask
    nd_mask = _pareto_filter(Y_all, S_all)
    Y_nd = Y_all[nd_mask]
    S_nd = S_all[nd_mask]
    T_nd = T_FLAT[nd_mask]
    tc_nd = CYC_FLAT[nd_mask]

    # Sort front by increasing S (left to right on the plot)
    order = np.argsort(S_nd)
    Y_nd, S_nd, T_nd, tc_nd = Y_nd[order], S_nd[order], T_nd[order], tc_nd[order]

    # Feasibility classification
    can_meet_S = bool(S_nd.min() <= S_ANODE_MAX)
    can_meet_C = bool(C_pred >= C_ANODE_MIN)
    feasible   = can_meet_S and can_meet_C

    # Fraction of front below the sulfur ceiling
    frac_below_S = float(np.mean(S_nd <= S_ANODE_MAX))

    pareto_results.append(dict(
        name=name, feed=feed, colour=colour,
        Y_all=Y_all, S_all=S_all,
        Y_nd=Y_nd, S_nd=S_nd, T_nd=T_nd, tc_nd=tc_nd,
        C_pred=C_pred,
        can_meet_S=can_meet_S, can_meet_C=can_meet_C, feasible=feasible,
        frac_below_S=frac_below_S
    ))

    verdict = ("ANODE-FEASIBLE" if feasible
               else "FAILS S-CEILING" if not can_meet_S
               else "FAILS C-FLOOR")
    print(f"{name:<42}{len(Y_nd):>8}{Y_nd.min():>8.2f}{Y_nd.max():>8.2f}"
          f"{S_nd.min():>8.3f}{S_nd.max():>8.3f}{C_pred:>8.2f}  {verdict}")

print()
print("  Note: S_min and S_max bound the non-dominated front (not the full grid).")
print(f"  Sulfur floor ({SULFUR_FLOOR} wt%) means no front point can lie below this value.")



# --------------------------------------------------------------------------
# 13B.3  Figure 13A— Pareto Operating Map: optimal T and t_c along each front
# --------------------------------------------------------------------------


fig13b, axes13b = plt.subplots(1, 2, figsize=(15, 6.5))
fig13b.suptitle(
    "Figure 13A — Pareto Operating Map: Furnace Temperature and Cycle Time\n"
    "along Each Non-Dominated Front (coloured by Predicted Coke Sulfur)",
    fontsize=13, fontweight='bold', y=1.02
)

for ax_idx, (ax, x_col, x_label) in enumerate(zip(
        axes13b,
        ['T_nd',  'tc_nd'],
        ['Furnace Outlet Temperature (°C)', 'Drum Cycle Time (h)'])):

    for res in pareto_results:
        x_vals = res[x_col]
        sc = ax.scatter(
            x_vals, res['S_nd'],
            c=res['S_nd'], cmap='magma',
            vmin=SULFUR_FLOOR, vmax=max(r['S_nd'].max() for r in pareto_results),
            s=18, alpha=0.55, edgecolors='none'
        )
        # Overlay coloured line per scenario
        ax.plot(x_vals, res['S_nd'], color=res['colour'],
                lw=1.5, alpha=0.7, label=res['name'])

    ax.axhline(S_ANODE_MAX, color='#c0392b', lw=1.4, ls='--', alpha=0.85,
               label=f'Anode S ceiling ({S_ANODE_MAX} wt%)')
    ax.axhline(SULFUR_FLOOR, color='#7f8c8d', lw=0.9, ls=':', alpha=0.7)

    ax.set_xlabel(x_label, fontsize=10)
    ax.set_ylabel('Predicted Coke Sulfur along Front (wt%)', fontsize=10)
    ax.set_title(f"{x_label.split('(')[0].strip()} operating map", fontsize=11,
                 fontweight='bold', color='#2c3e50')

    scenario_handles = [
        Line2D([0], [0], color=res['colour'], lw=1.8, label=res['name'])
        for res in pareto_results
    ]
    ax.legend(handles=scenario_handles, fontsize=8, loc='best', framealpha=0.9)

plt.colorbar(sc, ax=axes13b[1], label='Predicted Coke Sulfur (wt%)')
plt.tight_layout(rect=[0, 0, 1, 0.96])
plt.savefig('Figure_13B_Pareto_Operating_Map.png', dpi=150, bbox_inches='tight')
plt.show()
print("Figure 13B saved.")



