print(f"    Ni range               : {Ni_lo:.1f} → {Ni_hi:.1f} ppm  (Δ = {Ni_range:.1f})")
print(f"    Δ coke sulfur          : {effect_Ni:.3f} wt%")
print()
if effect_Ni > 0 and effect_T > 0:
    print(f"  Dominance ratio (Ni / T) : {effect_Ni/effect_T:.1f}×")
    print(f"  → Nickel is {effect_Ni/effect_T:.1f}x more influential than furnace temperature")
    print(f"    over their respective industrial operating ranges.")
