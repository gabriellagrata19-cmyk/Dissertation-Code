invT_hi      = float(_c_to_inv_t(T_lo))                   # inv_T at 440°C (larger)
invT_range   = invT_hi - invT_lo
Ni_lo, Ni_hi = TEMP_NI_NI_RANGE                           # 0, 120 ppm
