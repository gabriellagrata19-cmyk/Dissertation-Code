def legend_handles(origins=None):
    seen, handles = {}, []
    for origin, sty in ORIGIN_STYLE.items():
        if origins is not None and origin not in origins:
            continue
        if sty['color'] not in seen:
            seen[sty['color']] = True
            handles.append(Line2D([0],[0], marker=sty['marker'], color='w',
                                  markerfacecolor=sty['color'],
                                  markersize=10 if sty['marker']=='*' else 9,
                                  label=origin))
    return handles

def invT_to_C(inv_t): return (1000.0 / inv_t) - 273.15
def C_to_invT(t_c): return 1000.0 / (t_c + 273.15)
def ln_to_h(ln_t): return np.exp(ln_t)
def h_to_ln(h): return np.log(h)

# ==========================================================================
# PHYSICAL CONSTRAINTS — applied to ALL predictions / estimations
# ==========================================================================
SULFUR_FLOOR = 1.0  # wt%

# Methodological note for Section 3.4 of the dissertation:
#   Industrial petroleum coke from delayed coking carries residual organic
#   sulfur from the resin/asphaltene fraction.  Literature surveys
#   (Edwards 2014, Predel 2014) place the practical floor for refinery-
#   grade petroleum coke at ~1 wt% S even for sweet feeds.  Observations
#   reporting coke S < 1 wt% are inconsistent with this physical bound and
#   are excluded from regression to prevent biased extrapolation.

T_RANGE_C       = (430.0, 520.0)
CYCLE_RANGE_H   = (14.0, 40.0)
INV_T_PLOT_LIM  = (1000.0/(T_RANGE_C[1] + 273.15),
                   1000.0/(T_RANGE_C[0] + 273.15))

# Dedicated display window for coke sulfur versus temperature plots.
# The sulfur model is physically clipped at S = 1 wt%; this plotting window
# restricts the displayed sulfur-temperature regression to the region before
# the floored baseline dominates the graph (approximately 520 to 440 °C).
SULFUR_TEMP_RANGE_C = (440.0, 520.0)
SULFUR_INV_T_PLOT_LIM = (1000.0/(SULFUR_TEMP_RANGE_C[1] + 273.15),
                         1000.0/(SULFUR_TEMP_RANGE_C[0] + 273.15))

LN_CYCLE_PLOT_LIM = (np.log(CYCLE_RANGE_H[0]),
                     np.log(CYCLE_RANGE_H[1]))

def is_sulfur_response(y_col_or_label):
    s = str(y_col_or_label)
    return ('coke_s' == s) or ('Sulfur' in s) or ('sulfur' in s)

def apply_floor_if_sulfur(y, y_col_or_label):
    if is_sulfur_response(y_col_or_label):
        return np.maximum(np.asarray(y, dtype=float), SULFUR_FLOOR)
    return y

